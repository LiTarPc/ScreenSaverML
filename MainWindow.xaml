<Window x:Class="ScreenshotSaver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Screenshot Saver &amp; Editor" Height="650" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#121214"
        Foreground="#E4E4E7"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        Icon="icon.png">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" 
                      ResizeBorderThickness="6" 
                      GlassFrameThickness="1" 
                      CornerRadius="8"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Modern Custom Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D32"/>
            <Setter Property="Foreground" Value="#E4E4E7"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3D3D42"/>
                                <Setter Property="BorderBrush" Value="#52525B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E1E22"/>
                                <Setter Property="BorderBrush" Value="#27272A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tool Selection Button Style (Styled RadioButton) -->
        <Style x:Key="ToolRadioButton" TargetType="RadioButton">
            <Setter Property="Background" Value="#202024"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="BorderBrush" Value="#2F2F35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="Tools"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,3">
                            <StackPanel Orientation="Horizontal">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D32"/>
                                <Setter Property="Foreground" Value="#E4E4E7"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#0086F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Color Circle RadioButton Style -->
        <Style x:Key="ColorRadioButton" TargetType="RadioButton">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="Colors"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Ellipse x:Name="ColorCircle" Fill="{TemplateBinding Background}" Stroke="Transparent" StrokeThickness="2"/>
                            <Ellipse x:Name="SelectionRing" Stroke="White" StrokeThickness="2" Margin="-3" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SelectionRing" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ColorCircle" Property="Stroke" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E4E4E7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Custom TitleBar -->
            <RowDefinition Height="40"/>
            <!-- Main Content Area -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR (Drag area) -->
        <Grid Grid.Row="0" Background="#18181C" Name="TitleBarGrid" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                <Image Source="icon.png" Width="18" Height="18" Margin="0,0,10,0" IsHitTestVisible="False"/>
                <TextBlock Text="Screenshot Saver &amp; Editor" FontWeight="SemiBold" FontSize="13" Foreground="#E4E4E7" IsHitTestVisible="False"/>
            </StackPanel>

            <!-- Window Controls -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch" WindowChrome.IsHitTestVisibleInChrome="True">
                <!-- Minimize -->
                <Button Name="BtnTitleMinimize" Width="46" Background="Transparent" BorderBrush="Transparent" Click="BtnTitleMinimize_Click" Focusable="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent">
                                <Path Data="M 0 0 L 10 0" Stroke="#E4E4E7" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#2D2D30"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <!-- Close -->
                <Button Name="BtnTitleClose" Width="46" Background="Transparent" BorderBrush="Transparent" Click="BtnTitleClose_Click" Focusable="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent">
                                <Path Data="M 0 0 L 10 10 M 10 0 L 0 10" Stroke="#E4E4E7" StrokeThickness="1.2" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <!-- MAIN LAYOUT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <ColumnDefinition Width="270"/>
                <!-- Work Area -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="#1E1E24" BorderBrush="#2F2F35" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,12" VerticalAlignment="Stretch">
                        
                        <!-- Tools Section -->
                        <TextBlock Text="ИНСТРУМЕНТЫ" FontSize="11" FontWeight="Bold" Foreground="#71717A" Margin="0,0,0,8"/>
                        <RadioButton Style="{StaticResource ToolRadioButton}" Name="RbPen" IsChecked="True" Checked="Tool_Checked">
                            <TextBlock Text="🖊️  Рисование кистью"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ToolRadioButton}" Name="RbRectangle" Checked="Tool_Checked">
                            <TextBlock Text="⬜  Прямоугольник"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ToolRadioButton}" Name="RbEraser" Checked="Tool_Checked">
                            <TextBlock Text="🧹  Ластик"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ToolRadioButton}" Name="RbCrop" Checked="Tool_Checked">
                            <TextBlock Text="✂️  Обрезка кадра"/>
                        </RadioButton>

                        <!-- Colors Section -->
                        <TextBlock Text="ЦВЕТ РИСОВАНИЯ" FontSize="11" FontWeight="Bold" Foreground="#71717A" Margin="0,18,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,4">
                            <RadioButton Style="{StaticResource ColorRadioButton}" Name="RbColorRed" Background="#FF3B30" IsChecked="True" Checked="Color_Checked" ToolTip="Красный"/>
                            <RadioButton Style="{StaticResource ColorRadioButton}" Name="RbColorGreen" Background="#34C759" Checked="Color_Checked" ToolTip="Зеленый"/>
                            <RadioButton Style="{StaticResource ColorRadioButton}" Name="RbColorBlue" Background="#007AFF" Checked="Color_Checked" ToolTip="Синий"/>
                            <RadioButton Style="{StaticResource ColorRadioButton}" Name="RbColorYellow" Background="#FFCC00" Checked="Color_Checked" ToolTip="Желтый"/>
                        </StackPanel>

                        <!-- Brush Size Slider -->
                        <TextBlock Text="ТОЛЩИНА КИСТИ" FontSize="11" FontWeight="Bold" Foreground="#71717A" Margin="0,14,0,4"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" Name="SliderBrushSize" Minimum="1" Maximum="20" Value="3" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" ValueChanged="SliderBrushSize_ValueChanged"/>
                            <TextBlock Grid.Column="1" Text="{Binding ElementName=SliderBrushSize, Path=Value}" Foreground="#A1A1AA" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Zoom Section -->
                        <TextBlock Text="МАСШТАБ" FontSize="11" FontWeight="Bold" Foreground="#71717A" Margin="0,14,0,4"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Name="TxtZoomPercent" Text="Масштаб: 100%" Foreground="#E4E4E7" FontSize="13" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="🔄 Сброс" Click="BtnResetZoom_Click" Padding="8,4" FontSize="11"/>
                        </Grid>

                        <Separator Background="#2F2F35" Margin="0,16"/>

                        <!-- Actions Section -->
                        <TextBlock Text="ДЕЙСТВИЯ" FontSize="11" FontWeight="Bold" Foreground="#71717A" Margin="0,0,0,8"/>
                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <Button Style="{StaticResource ModernButton}" Content="📋 Вставить" Click="BtnPaste_Click" Margin="0,0,4,0"/>
                            <Button Style="{StaticResource ModernButton}" Content="🗑️ Очистить" Click="BtnClear_Click" Margin="4,0,0,0"/>
                        </UniformGrid>
                        <Button Style="{StaticResource ModernButton}" Content="💾 Сохранить изображение" Click="BtnSave_Click" FontWeight="SemiBold" Background="#0D723B" BorderBrush="#1B824B" Margin="0,0,0,8"/>

                        <Separator Background="#2F2F35" Margin="0,16"/>

                        <!-- Settings Section -->
                        <TextBlock Text="НАСТРОЙКИ" FontSize="11" FontWeight="Bold" Foreground="#71717A" Margin="0,0,0,8"/>
                        
                        <CheckBox Name="CbAutoSave" Content="Автосохранение (Win+Shift+S)" Checked="CbAutoSave_Changed" Unchecked="CbAutoSave_Changed"/>
                        <CheckBox Name="CbRunAtStartup" Content="Запуск при старте Windows" Checked="CbRunAtStartup_Changed" Unchecked="CbRunAtStartup_Changed"/>
                        <CheckBox Name="CbMinimizeToTray" Content="Сворачивать в трей при закрытии" Checked="CbMinimizeToTray_Changed" Unchecked="CbMinimizeToTray_Changed"/>

                        <!-- Target Folder Selector -->
                        <TextBlock Text="ПАПКА СОХРАНЕНИЯ" FontSize="11" FontWeight="Bold" Foreground="#71717A" Margin="0,14,0,4"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Name="TxtSaveFolder" IsReadOnly="True" Background="#121214" BorderBrush="#2F2F35" Foreground="#A1A1AA" FontSize="11" Padding="6,6" VerticalContentAlignment="Center" ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                            <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="..." Click="BtnChooseFolder_Click" Margin="4,0,0,0" Padding="0"/>
                        </Grid>
                        <Button Style="{StaticResource ModernButton}" Content="📂 Открыть папку со скринами" Click="BtnOpenFolder_Click"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- VIEWPORT AREA -->
            <Grid Grid.Column="1" Background="#121214">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#121214" BorderThickness="0" PreviewMouseWheel="Workspace_PreviewMouseWheel">
                    <Grid Name="MainGrid" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20"
                          MouseLeftButtonDown="MainGrid_MouseLeftButtonDown"
                          MouseMove="MainGrid_MouseMove"
                          MouseLeftButtonUp="MainGrid_MouseLeftButtonUp"
                          PreviewMouseLeftButtonDown="MainGrid_PreviewMouseLeftButtonDown">
                        <Grid.LayoutTransform>
                            <ScaleTransform x:Name="GridScale" ScaleX="1.0" ScaleY="1.0"/>
                        </Grid.LayoutTransform>
                        
                        <!-- Image Element -->
                        <Image Name="ScreenshotImage" Stretch="None">
                            <Image.Effect>
                                <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.4" ShadowDepth="3"/>
                            </Image.Effect>
                        </Image>
                        
                        <!-- Drawings canvas -->
                        <InkCanvas Name="DrawingCanvas" Background="Transparent" />
                        
                        <!-- Shape overlay canvas -->
                        <Canvas Name="ShapesCanvas" Background="Transparent" />
                        
                        <!-- Crop overlay canvas -->
                        <Canvas Name="CropCanvas" Background="Transparent" Visibility="Collapsed">
                            <Path Name="CropOverlay" Fill="#A0000000" />
                            <Rectangle Name="CropSelectionRect" Stroke="#0078D4" StrokeThickness="2" StrokeDashArray="4,3"/>
                        </Canvas>
                    </Grid>
                </ScrollViewer>

                <!-- Placeholder Grid -->
                <Grid Name="PlaceholderGrid" Background="#121214" IsHitTestVisible="False" Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                        <TextBlock Text="📸" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Ожидание изображения" FontSize="18" FontWeight="SemiBold" Foreground="#E4E4E7" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Сделайте снимок экрана (Win + Shift + S)" FontSize="13" Foreground="#71717A" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="или вставьте изображение из буфера обмена (Ctrl + V)" FontSize="13" Foreground="#71717A" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
